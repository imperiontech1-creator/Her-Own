# Her Own – DO NOT paste real values here. All secrets come from Doppler only.
# Run: doppler run -- npm run dev  (project: her-own, config: dev)
# This file is for reference only; use Doppler for every secret.

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
HER_OWN_ADMIN_EMAIL=

# Optional: customer & admin emails (order confirmation, shipped, supplier notify)
# RESEND_API_KEY=
# RESEND_FROM=Her Own <orders@yourdomain.com>
# Optional: public site URL for links in emails (defaults to request origin)
# NEXT_PUBLIC_SITE_URL=https://your-site.com
# Optional: secret for /api/notify-supplier (webhook sends header x-her-own-notify-secret); if set, requests without it get 401
# HER_OWN_NOTIFY_SECRET=

# Optional: site offline / maintenance (1 = show "We'll be back soon", allow tracking/admin/webhook)
# HER_OWN_SITE_OFFLINE=
# HER_OWN_MAINTENANCE=

# Optional: price multiplier at checkout (default 1.0; e.g. 1.15 for holiday)
# HER_OWN_PRICE_MULTIPLIER=
