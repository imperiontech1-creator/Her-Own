{
  "name": "her-own",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "doppler run -- next dev",
    "build": "doppler run -- next build",
    "build:ci": "next build",
    "start": "doppler run -- next start",
    "lint": "next lint",
    "netlify:env": "doppler secrets download --project her-own --config dev_personal --no-file --format env > .env.netlify",
    "netlify:login": "npx netlify login",
    "netlify:init": "npx netlify init",
    "netlify:import": "npx netlify env:import .env.netlify",
    "netlify:deploy": "npx netlify deploy --build --prod",
    "netlify:ship": "npm run netlify:env && npx netlify env:import .env.netlify && npx netlify deploy --build --prod",
    "stress-test": "node scripts/stress-test.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@stripe/stripe-js": "^4.8.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.454.0",
    "next": "15.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.2.0",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "netlify-cli": "^17.0.0"
  }
}
